		{
			"name": "Products Service - Complete SAGA Flow",
			"item": [
				{
					"name": "1. Create Product",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.collectionVariables.set('product_id', jsonData.id);",
									"    console.log('Saved product_id: ' + jsonData.id);",
									"}",
									"",
									"pm.test('Status 201', () => pm.response.to.have.status(201));",
									"pm.test('Name matches', () => pm.expect(jsonData.name).to.eql('SAGA Test Product'));",
									"pm.test('Price matches', () => pm.expect(jsonData.price).to.eql(49.99));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
