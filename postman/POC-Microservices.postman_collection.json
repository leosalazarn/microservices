					"name": "2. Update Product (Partial Price)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Name unchanged', () => pm.expect(jsonData.name).to.eql('SAGA Test Product'));",
									"pm.test('Price increased', () => pm.expect(jsonData.price).to.eql(79.99));",
									"",
									"console.log('Updated price from 49.99 to 79.99');"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"price\": 79.99\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/products/products/{{product_id}}",
							"host": ["{{gateway_url}}"],
							"path": ["products", "products", "{{product_id}}"]
						},
						"description": "Step 2: Partial price update → ProductUpdatedEvent captures old=49.99, new=79.99 → EventStore → Kafka."
					}
				},
				{
					"name": "3. Update Product (Full)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Name updated', () => pm.expect(jsonData.name).to.eql('SAGA Updated Name'));",
									"pm.test('Price updated', () => pm.expect(jsonData.price).to.eql(129.99));",
									"pm.test('Description updated', () => pm.expect(jsonData.description).to.eql('Updated via full update'));",
									"pm.test('Category updated', () => pm.expect(jsonData.category).to.eql('Updated'));",
									"",
									"console.log('Full update complete - all fields changed');"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"SAGA Updated Name\",\n  \"price\": 129.99,\n  \"description\": \"Updated via full update\",\n  \"category\": \"Updated\"\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/products/products/{{product_id}}",
							"host": ["{{gateway_url}}"],
							"path": ["products", "products", "{{product_id}}"]
						},
						"description": "Step 3: Full update → all 4 fields change → ProductUpdatedEvent captures old+new for each → EventStore → Kafka."
					}
				},
				{
					"name": "4. Verify by Query",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"var updatedProduct = jsonData.find(p => p.id === pm.collectionVariables.get('product_id'));",
									"",
									"if (updatedProduct) {",
									"    pm.test('Name persisted', () => pm.expect(updatedProduct.name).to.eql('SAGA Updated Name'));",
									"    pm.test('Price persisted', () => pm.expect(updatedProduct.price).to.eql(129.99));",
									"    pm.test('Description persisted', () => pm.expect(updatedProduct.description).to.eql('Updated via full update'));",
									"    pm.test('Category persisted', () => pm.expect(updatedProduct.category).to.eql('Updated'));",
									"    console.log('All updates verified in query response');",
									"} else {",
									"    pm.test('Product found in list', false, 'product not in query result');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{gateway_url}}/products/products",
							"host": ["{{gateway_url}}"],
							"path": ["products", "products"]
						},
						"description": "Step 4: Query all products and verify updates persisted to read model."
					}
				},
