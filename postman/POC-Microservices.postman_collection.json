		{
			"name": "Products Service - Command (CQRS Write)",
			"item": [
				{
					"name": "Create Product",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.collectionVariables.set('product_id', jsonData.id);",
									"    console.log('Saved product_id: ' + jsonData.id);",
									"}",
									"",
									"pm.test('Status 201', () => pm.response.to.have.status(201));",
									"pm.test('Has id', () => pm.expect(jsonData.id).to.not.be.empty);",
									"pm.test('Has name', () => pm.expect(jsonData.name).to.eql('New Product'));",
									"pm.test('Has price', () => pm.expect(jsonData.price).to.eql(99.99));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"New Product\",\n  \"price\": 99.99,\n  \"description\": \"Product description\",\n  \"category\": \"Electronics\"\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/products/products",
							"host": ["{{gateway_url}}"],
							"path": ["products", "products"]
						},
						"description": "Create product via Command Bus → ProductAggregate.applyProductCreated() → EventStore (MongoDB) → DomainEventPublisher → Kafka [product-events].\nReturns MongoDB ObjectId as 'id'. Auto-saves id to collection variable `product_id`."
					}
				},
				{
					"name": "Update Product (Full)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.name) {",
									"    pm.collectionVariables.set('updated_name', jsonData.name);",
									"    console.log('Saved updated_name: ' + jsonData.name);",
									"}",
									"if (jsonData.price) {",
									"    pm.collectionVariables.set('updated_price', String(jsonData.price));",
									"    console.log('Saved updated_price: ' + jsonData.price);",
									"}",
									"",
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Name updated', () => pm.expect(jsonData.name).to.eql('Updated Product Name'));",
									"pm.test('Price updated', () => pm.expect(jsonData.price).to.eql(149.99));",
									"pm.test('Description updated', () => pm.expect(jsonData.description).to.eql('Updated description'));",
									"pm.test('Category updated', () => pm.expect(jsonData.category).to.eql('Updated Category'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Updated Product Name\",\n  \"price\": 149.99,\n  \"description\": \"Updated description\",\n  \"category\": \"Updated Category\"\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/products/products/{{product_id}}",
							"host": ["{{gateway_url}}"],
							"path": ["products", "products", "{{product_id}}"]
						},
						"description": "Full update — all fields changed.\nFlow: UpdateProductCommand → ProductAggregate.updateName/updatePrice/updateDescription/updateCategory → capture old state → applyProductUpdated(oldN, oldP, oldD, oldC) → ProductUpdatedEvent with old+new values → EventStore.saveAll() → DomainEventPublisher → Kafka [product-events].\nOld values are tracked in the event for full audit trail.\nAuto-saves updated_name and updated_price to collection variables."
					}
				},
				{
					"name": "Update Product (Price Only)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.price) {",
									"    pm.collectionVariables.set('updated_price', String(jsonData.price));",
									"    console.log('Saved updated_price: ' + jsonData.price);",
									"}",
									"",
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Price updated', () => pm.expect(jsonData.price).to.eql(199.99));",
									"pm.test('Name unchanged', () => pm.expect(jsonData.name).to.not.be.empty);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"price\": 199.99\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/products/products/{{product_id}}",
							"host": ["{{gateway_url}}"],
							"path": ["products", "products", "{{product_id}}"]
						},
						"description": "Partial update — price only (other fields unchanged).\nFlow: UpdateProductCommand → ProductAggregate.updatePrice() → capture old price → applyProductUpdated() → ProductUpdatedEvent with oldPrice=newPrice tracking → EventStore → Kafka.\nDemonstrates nullable-field support in UpdateProductCommand."
					}
				},
				{
					"name": "Update Product (Name Only)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.name) {",
									"    pm.collectionVariables.set('updated_name', jsonData.name);",
									"    console.log('Saved updated_name: ' + jsonData.name);",
									"}",
									"",
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Name updated', () => pm.expect(jsonData.name).to.eql('Renamed Product'));",
									"pm.test('Price unchanged', () => pm.expect(jsonData.price).to.be.a('number'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Renamed Product\"\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/products/products/{{product_id}}",
							"host": ["{{gateway_url}}"],
							"path": ["products", "products", "{{product_id}}"]
						},
						"description": "Partial update — name only.\nFlow: UpdateProductCommand(name set, others null) → ProductAggregate.updateName() → ProductUpdatedEvent with oldName → newName → EventStore → Kafka.\nDemonstrates that null fields are ignored by the handler."
					}
