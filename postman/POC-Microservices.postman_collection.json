						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"SAGA Test Product\",\n  \"price\": 49.99,\n  \"description\": \"Created for SAGA flow test\",\n  \"category\": \"Testing\"\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/products/products",
							"host": ["{{gateway_url}}"],
							"path": ["products", "products"]
						},
						"description": "Step 1: Create product → ProductCreatedEvent → EventStore → Kafka."
					}
				},
