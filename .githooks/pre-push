#!/bin/sh
# Pre-push hook: run full Gradle build (compilation + tests).
# Aborts push if build fails.

if [ -z "$JAVA_HOME" ]; then
  for dir in "$HOME/.jdks" "/c/Users/$USER/.jdks" "/c/Users/$(whoami)/.jdks"; do
    if [ -d "$dir" ]; then
      for jdk in "$dir"/*; do
        if [ -x "$jdk/bin/java" ]; then
          export JAVA_HOME="$jdk"
          break 2
        fi
      done
    fi
  done
fi

echo "=== Pre-push: Running gradle build (JAVA_HOME=$JAVA_HOME) ==="
./gradlew build --no-daemon
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo "=== BUILD FAILED (exit code $EXIT_CODE) — Push aborted ==="
  exit 1
fi

echo "=== Build passed — Proceeding with push ==="
exit 0
